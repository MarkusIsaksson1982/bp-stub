{
  "name": "@foundation/core",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready foundation for voice and speech technology prototypes",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "tsc --noEmit",
    "compose": "docker compose -f docker-compose.foundation.yml up -d --build",
    "compose:down": "docker compose -f docker-compose.foundation.yml down",
    "db:migrate": "turbo run migrate:up --filter=@foundation/db",
    "db:seed": "turbo run seed --filter=@foundation/db"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "@tsconfig/node20": "^1.0.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": "22.x"
  }
}