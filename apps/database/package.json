{
  "name": "@foundation/db",
  "version": "1.0.0",
  "description": "PostgreSQL schema foundation for voice and speech technology",
  "main": "index.js",
  "scripts": {
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:redo": "node-pg-migrate redo",
    "seed": "psql $DATABASE_URL -f seed/seed.sql",
    "setup": "./scripts/setup.sh",
    "reset": "./scripts/reset.sh"
  },
  "keywords": [
    "postgresql",
    "database",
    "schema",
    "migrations",
    "voice",
    "speech",
    "foundation"
  ],
  "license": "MIT",
  "devDependencies": {
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "node-pg-migrate": {
    "migration-file-language": "sql",
    "migrations-dir": "migrations",
    "schema-file": "docs/SCHEMA.md"
  }
}
