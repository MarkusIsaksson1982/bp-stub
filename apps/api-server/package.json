{
  "name": "@foundation/api",
  "version": "1.0.0",
  "description": "Production Express.js REST API foundation with ML inference support",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --runInBand",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@foundation/logger": "file:../../packages/logger",
    "@foundation/healthcheck": "file:../../packages/healthcheck",
    "@foundation/core": "file:../../packages/core",
    "@foundation/metrics": "file:../../packages/metrics",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1",
    "helmet": "^8.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "clearMocks": true,
    "testEnvironment": "node"
  },
  "eslintConfig": {
    "env": {
      "es2022": true,
      "jest": true,
      "node": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2022
    },
    "rules": {
      "no-console": "off"
    }
  }
}
