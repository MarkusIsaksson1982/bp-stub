{
  "title": "PostgreSQL Metrics",
  "uid": "postgres-metrics",
  "tags": ["observatory", "database"],
  "panels": [
    {
      "title": "Connections",
      "type": "timeseries",
      "targets": [{ "expr": "pg_stat_activity_count" }]
    },
    {
      "title": "Query Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(pg_stat_database_tup_fetched[5m])" }]
    },
    {
      "title": "Deadlocks",
      "type": "stat",
      "targets": [{ "expr": "pg_locks_deadlock_count" }]
    }
  ]
}